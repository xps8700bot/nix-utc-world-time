{
  "root": true,
  "env": {
    "browser": true,
    "es6": true
  },
  "globals": {
    "chrome": "readonly"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "env": { "node": true, "es2021": true }
    }
  ],
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  }
}
